module ClearingTest where

import Daml.Script
import DA.Date
import DA.Time
import DA.Assert

import Clearing (ClearedDerivative, TradeDetails(..))
import Margin (MarginAccount, VariationMarginCall)
import DefaultManagement (DefaultNotice, DefaultProcess)
import Novation (NovationProposal)

-- === Test Scenarios for Clearing Workflow ===

clearingTest : Script ()
clearingTest = script do
  -- Party Setup
  ccp <- allocatePartyWithHint "Clearinghouse" (PartyIdHint "ccp")
  memberA <- allocatePartyWithHint "MemberA" (PartyIdHint "membera")
  memberB <- allocatePartyWithHint "MemberB" (PartyIdHint "memberb")
  memberC <- allocatePartyWithHint "MemberC" (PartyIdHint "memberc") -- For novation test

  -- Run tests
  testHappyPathMarginCall ccp memberA memberB
  testDefaultOnMarginCall ccp memberA memberB
  testNovation ccp memberA memberB memberC

-- Test 1: Happy path for MTM update and variation margin settlement.
testHappyPathMarginCall : Party -> Party -> Party -> Script ()
testHappyPathMarginCall ccp memberA memberB = do
  debug "Running testHappyPathMarginCall..."

  -- 1. Setup Initial State: Margin accounts and a cleared derivative contract.
  let initialMargin = 10000.0
  marginAccountACid <- submit ccp do
    createCmd MarginAccount with ccp, member = memberA, balance = 0.0, lockedBalance = 0.0
  marginAccountBCid <- submit ccp do
    createCmd MarginAccount with ccp, member = memberB, balance = 0.0, lockedBalance = 0.0

  submit memberA do exerciseCmd marginAccountACid MarginAccount.Deposit with amount = initialMargin
  submit memberB do exerciseCmd marginAccountBCid MarginAccount.Deposit with amount = initialMargin

  let trade = TradeDetails with
        tradeId = "ISIN-12345"
        tradeDate = date 2024 Jan 1
        effectiveDate = date 2024 Jan 3
        maturityDate = date 2025 Jan 3
        notional = 1_000_000.0
        currency = "USD"
        fixedRate = 0.05
        floatingRateIndex = "SOFR"

  clearedDerivativeCid <- submit ccp do
    createCmd ClearedDerivative with
      ccp, memberA, memberB, trade, mtm = 0.0

  -- 2. CCP updates MTM, creating a loss for Member A.
  -- This should trigger the creation of a VariationMarginCall contract.
  let mtmUpdate = -5000.0
  (callCid, _) <- submit ccp do
    exerciseCmd clearedDerivativeCid ClearedDerivative.UpdateMtm with
      newMtm = mtmUpdate
      currentTime = getTime

  -- 3. Verify the VariationMarginCall exists and is correct.
  callContract <- queryContractId ccp callCid
  debug $ "Variation Margin Call created: " <> show callContract
  callContract.payer === memberA
  callContract.receiver === memberB
  callContract.amount === abs mtmUpdate

  -- 4. Member A (the payer) settles the margin call.
  submit memberA do
    exerciseCmd callCid VariationMarginCall.Settle

  -- 5. Verify the margin call contract is consumed and balances are updated.
  queryContractId ccp callCid >>= \case
    Some _ -> abort "VariationMarginCall contract should have been archived after settlement."
    None   -> pure ()

  updatedMarginAccountA <- queryContractId memberA marginAccountACid
  updatedMarginAccountA.isSome.balance === initialMargin - abs mtmUpdate

  updatedMarginAccountB <- queryContractId memberB marginAccountBCid
  updatedMarginAccountB.isSome.balance === initialMargin + abs mtmUpdate

  debug "testHappyPathMarginCall successful."
  pure ()

-- Test 2: A member fails to meet a margin call, leading to a default.
testDefaultOnMarginCall : Party -> Party -> Party -> Script ()
testDefaultOnMarginCall ccp memberA memberB = do
  debug "Running testDefaultOnMarginCall..."

  -- 1. Setup Initial State (similar to happy path).
  let initialMargin = 10000.0
  marginAccountACid <- submit ccp do createCmd MarginAccount with ccp, member = memberA, balance = initialMargin, lockedBalance = 0.0
  _ <- submit ccp do createCmd MarginAccount with ccp, member = memberB, balance = initialMargin, lockedBalance = 0.0

  let trade = TradeDetails with tradeId = "ISIN-DEF-01", tradeDate = date 2024 Feb 1, effectiveDate = date 2024 Feb 3, maturityDate = date 2025 Feb 3, notional = 2_000_000.0, currency = "USD", fixedRate = 0.04, floatingRateIndex = "LIBOR"
  clearedDerivativeCid <- submit ccp do
    createCmd ClearedDerivative with ccp, memberA, memberB, trade, mtm = 0.0

  -- 2. CCP updates MTM, creating a VariationMarginCall for Member A.
  let mtmUpdate = -7500.0
  (callCid, _) <- submit ccp do
    exerciseCmd clearedDerivativeCid ClearedDerivative.UpdateMtm with
      newMtm = mtmUpdate
      currentTime = getTime

  -- 3. Time passes, and Member A fails to pay. CCP declares default.
  -- We simulate this by directly calling the DeclareDefault choice.
  -- In a real system, this would be triggered by a time-out check.
  (defaultNoticeCid, defaultProcessCid) <- submit ccp do
    exerciseCmd clearedDerivativeCid ClearedDerivative.DeclareDefault with
      defaultingMember = memberA
      reason = "Failure to meet variation margin call " <> show callCid
      currentTime = getTime

  -- 4. Verify that the DefaultNotice and DefaultProcess contracts were created.
  defaultNotice <- queryContractId ccp defaultNoticeCid
  defaultNotice.isSome.defaultingMember === memberA
  defaultNotice.isSome.reason === "Failure to meet variation margin call " <> show callCid
  debug $ "DefaultNotice created: " <> show defaultNotice

  defaultProcess <- queryContractId ccp defaultProcessCid
  defaultProcess.isSome.defaultingMember === memberA
  defaultProcess.isSome.unpaidMarginCalls === [callCid]
  debug $ "DefaultProcess created: " <> show defaultProcess

  -- 5. CCP uses the DefaultProcess to seize collateral to cover the loss.
  -- The original ClearedDerivative should be archived.
  submit ccp do
    exerciseCmd defaultProcessCid DefaultProcess.ResolvePosition

  -- 6. Verify results: collateral seized, original trade terminated.
  updatedMarginAccountA <- queryContractId memberA marginAccountACid
  updatedMarginAccountA.isSome.balance === initialMargin - abs mtmUpdate
  debug $ "Member A's margin account balance reduced to cover loss: " <> show updatedMarginAccountA.isSome.balance

  queryContractId ccp clearedDerivativeCid >>= \case
    Some _ -> abort "ClearedDerivative should have been archived after default resolution."
    None   -> pure ()

  debug "testDefaultOnMarginCall successful."
  pure ()

-- Test 3: An existing cleared position is novated from Member A to Member C.
testNovation : Party -> Party -> Party -> Party -> Script ()
testNovation ccp memberA memberB memberC = do
  debug "Running testNovation..."

  -- 1. Setup Initial State:
  -- Member A and B have a cleared trade.
  -- Member C will be the transferee.
  let initialMargin = 10000.0
  _ <- submit ccp do createCmd MarginAccount with ccp, member = memberA, balance = initialMargin, lockedBalance = 0.0
  _ <- submit ccp do createCmd MarginAccount with ccp, member = memberB, balance = initialMargin, lockedBalance = 0.0
  marginAccountCCid <- submit ccp do createCmd MarginAccount with ccp, member = memberC, balance = 0.0, lockedBalance = 0.0
  submit memberC do exerciseCmd marginAccountCCid MarginAccount.Deposit with amount = initialMargin -- Pre-fund for novation

  let trade = TradeDetails with tradeId = "ISIN-NOV-02", tradeDate = date 2024 Mar 1, effectiveDate = date 2024 Mar 3, maturityDate = date 2025 Mar 3, notional = 500_000.0, currency = "EUR", fixedRate = 0.03, floatingRateIndex = "EURIBOR"
  originalCid <- submit ccp do
    createCmd ClearedDerivative with ccp, memberA, memberB, trade, mtm = 1200.0 -- MTM is non-zero

  -- 2. Member A (transferor) proposes to novate their position to Member C (transferee).
  proposalCid <- submit memberA do
    exerciseCmd originalCid ClearedDerivative.ProposeNovation with
      transferee = memberC

  -- 3. All parties must agree: Transferee (C), Remaining Counterparty (B), and CCP.
  proposalCid' <- submit memberC do
    exerciseCmd proposalCid NovationProposal.Accept
  proposalCid'' <- submit memberB do
    exerciseCmd proposalCid' NovationProposal.Accept
  (newCid, _) <- submit ccp do
    exerciseCmd proposalCid'' NovationProposal.Accept

  -- 4. Verify the outcome.
  -- a) The original proposal is archived.
  queryContractId ccp proposalCid'' >>= \case
    Some _ -> abort "NovationProposal should be archived after final acceptance."
    None   -> pure ()

  -- b) The original derivative contract between A and B is archived.
  queryContractId ccp originalCid >>= \case
    Some _ -> abort "Original ClearedDerivative should be archived after novation."
    None   -> pure ()

  -- c) A new derivative contract exists between C and B.
  newContract <- queryContractId ccp newCid
  debug $ "Novated contract created: " <> show newContract
  newContract.isSome.memberA === memberC -- The 'A' slot is now filled by C
  newContract.isSome.memberB === memberB
  newContract.isSome.trade.tradeId === trade.tradeId -- Same trade details
  newContract.isSome.mtm === 1200.0 -- MTM is carried over

  debug "testNovation successful."
  pure ()